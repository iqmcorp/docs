  "components": {
    "schemas": {
      "AddAssetRequestSchema": {
        "required": [
          "files",
          "filesMetadata"
        ],
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "description": "An array of multipart files to be uploaded as assets.",
            "format": "binary",
            "items": {
              "type": "string",
              "format": "binary"
            }
          },
          "filesMetadata": {
            "type": "string",
            "description": "A JSON string representing the metadata associated with the files. Each object in the array should contain: attachedFileName, originalFileName, and optional fields: disposable (default: false), zipFile (default: false), html5Creative (default: false).",
            "example": "[{\"attachedFileName\":\"image.png\",\"originalFileName\":\"image.png\",\"disposable\":false,\"zipFile\":false,\"html5Creative\":false}]"
          }
        },
        "description": "Request schema for adding multiple assets via multipart form data"
      },
      "AddAssetResponseVO": {
        "type": "object",
        "properties": {
          "assetID": {
            "type": "integer",
            "description": "The unique identifier assigned to the newly added asset.",
            "format": "int32",
            "example": 12345
          },
          "assetCDNURL": {
            "type": "string",
            "description": "The public URL of the CDN where the asset is stored.",
            "example": "https://cdn.example.com/assets/12345"
          },
          "dimensions": {
            "$ref": "#/components/schemas/CreativeDimensionsVO"
          },
          "iframeHtml": {
            "type": "string",
            "description": "Ready-to-use iframe HTML code for HTML5 creatives. Only present for HTML5 creatives.",
            "example": "\u003Ciframe src=\"https://cdn.example.com/creative/index.html\" width=\"160\" height=\"600\" frameborder=\"0\" scrolling=\"no\" marginheight=\"0\" marginwidth=\"0\"\u003E\u003C/iframe\u003E"
          }
        },
        "description": "Response object for adding a new asset to the system."
      },
      "AddAssetsResponseSchema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Indicates whether the operation was successful",
            "example": true
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/AddAssetResponseVO"
            },
            "description": "Map of file names to their asset response details. Each key is the original file name and the value contains the asset ID and CDN URL."
          }
        },
        "description": "Response wrapper for add assets operation"
      },
      "CreativeDimensionsVO": {
        "type": "object",
        "properties": {
          "width": {
            "type": "integer",
            "format": "int32"
          },
          "height": {
            "type": "integer",
            "format": "int32"
          }
        },
        "description": "Dimensions of the asset (for HTML5 creatives). Contains width and height.",
        "nullable": true
      },
      "CommonResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errorObjects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ErrorObject"
            }
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorObject": {
        "type": "object",
        "properties": {
          "error": {
