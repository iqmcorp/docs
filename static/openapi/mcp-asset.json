    "/api/v3/asset/list": {
      "get": {
        "tags": [
          "MCP"
        ],
        "summary": "List All Assets by Organization Workspace ID",
        "description": "This API is used for fetching the list of all assets associated with a specific Organization Workspace ID.\n1. The API retrieves all assets linked to the Organization Workspace ID of the logged-in user.\n2. The response includes a list of assets, each containing details such as id, storage path, CDN URL,\ncreation timestamp, modification timestamp, and whether it is disposable.\n3. For HTML5 creative assets, the response includes assetDimensions (stored in JSONB format) and iframeHtml (ready-to-use iframe code).\n4. Appropriate error responses are provided for unauthorized access.\n",
        "operationId": "getAllAssets",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Authorization Bearer Token",
            "example": "Bearer 0ed52da8-24ab-44b1-bc88-7ea03a090d24",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "example": "{{bearer_token}}"
            }
          },
          {
            "name": "X-IAA-OW-ID",
            "in": "header",
            "description": "Organization Workspace Id",
            "example": 1,
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
