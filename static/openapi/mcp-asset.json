  "paths": {
    "/api/v3/asset": {
      "post": {
        "tags": [
          "MCP"
        ],
        "summary": "Add Multiple Assets to the System",
        "description": "This API is used for adding multiple assets to the system. It accepts an array of multipart files along with their associated metadata in JSON format.\n1. The 'files' parameter should contain the files to be uploaded.\n2. The 'filesMetadata' parameter should be a JSON string that provides metadata for each file. This metadata includes the attached file name,\noriginal file name and an optional key (default set to false) for whether the file is disposable.\n3. The API returns a map where each key is the original file name and the value is an AddAssetResponseVO containing details about the uploaded asset.\n4. Appropriate error responses are provided for invalid inputs or unauthorized access.\n",
        "operationId": "addAssets",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Authorization Bearer Token",
            "example": "Bearer 0ed52da8-24ab-44b1-bc88-7ea03a090d24",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "example": "{{bearer_token}}"
            }
          },
          {
            "name": "X-IAA-OW-ID",
            "in": "header",
            "description": "Organization Workspace Id",
            "example": 1,
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "description": "Multipart form data containing files and their metadata as JSON string",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AddAssetRequestSchema"
              },
              "encoding": {
                "filesMetadata": {
                  "contentType": "application/json"
                },
                "files": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddAssetsResponseSchema"
                },
                "examples": {
                  "Assets added successfully": {
                    "description": "Assets added successfully",
                    "value": {
                      "success": true,
                      "data": {
                        "9d41a99a-9761-44cf-a3db-307a57b65795.jpg": {
                          "assetID": 697,
                          "assetCDNURL": "https://cdn.example.com/assets/123456/IHp2jMI_1704987233847.jpg"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommonResponse"
                },
                "examples": {
                  "File metadata not provided": {
                    "description": "File metadata not provided",
                    "value": {
                      "success": false,
                      "errorObjects": [
                        {
                          "error": "Please pass File(s) metaData"
                        }
                      ]
                    }
                  },
                  "Multipart files not provided": {
                    "description": "Multipart files not provided",
                    "value": {
                      "success": false,
                      "errorObjects": [
                        {
                          "error": "Please attach file(s)"
                        }
                      ]
                    }
                  },
                  "File metadata is not a valid JSON": {
                    "description": "File metadata is not a valid JSON",
                    "value": {
                      "success": false,
                      "errorObjects": [
                        {
                          "error": "Please pass correct File(s) MetaData"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "errorObjects": [
                    {
                      "error": "server encountered an error !"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "errorObjects": [
                    {
                      "error": "Forbidden !"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/asset/{assetId}": {
      "get": {
        "tags": [
          "MCP"
        ],
        "summary": "Fetch Asset Details by Asset ID",
        "description": "This API is used for fetching the details of a single asset identified by its AssetID.\n1. The 'assetId' parameter should contain the ID of the asset to be fetched.\n2. The API returns the details of the asset including its storage path, CDN URL, creation timestamp, modification timestamp, and whether it is disposable.\n3. For HTML5 creative assets, the response includes assetDimensions (stored in JSONB format) and iframeHtml (ready-to-use iframe code).\n4. Appropriate error responses are provided for invalid inputs or unauthorized access.\n",
        "operationId": "getAssetDetails",
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "description": "The ID of the asset to fetch.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Authorization Bearer Token",
            "example": "Bearer 0ed52da8-24ab-44b1-bc88-7ea03a090d24",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "example": "{{bearer_token}}"
            }
          },
          {
            "name": "X-IAA-OW-ID",
            "in": "header",
            "description": "Organization Workspace Id",
            "example": 1,
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetDetailResponseSchema"
                },
                "examples": {
                  "Regular asset details fetched successfully": {
                    "description": "Regular asset details fetched successfully",
                    "value": {
                      "success": true,
                      "data": {
                        "id": 1,
                        "storagePath": "assets/201427/tfteBYO_1704204958735.jpg",
                        "cdnUrl": "https://cdn.example.com/assets/201427/tfteBYO_1704204958735.jpg",
                        "created": 1704204961147,
                        "modifiedDate": "2024-01-18T06:03:23.823+00:00",
                        "owId": 201427,
                        "createdByUowId": 2002,
                        "modifiedByUowId": 2003,
                        "assetDimensions": null,
                        "iframeHtml": null,
                        "zipFile": false,
                        "disposable": true,
                        "html5Creative": false
                      }
                    }
                  },
                  "HTML5 creative asset details fetched successfully": {
                    "description": "HTML5 creative asset details fetched successfully",
                    "value": {
                      "success": true,
                      "data": {
                         "id": 2,
                        "storagePath": "assets/201427/randomPath/index.html",
                        "cdnUrl": "https://cdn.example.com/assets/201427/randomPath/index.html",
                        "created": 1704204971010,
                        "modifiedDate": "2024-01-18T06:03:23.823+00:00",
                        "owId": 201427,
                        "createdByUowId": 2002,
                        "modifiedByUowId": 2003,
                        "assetDimensions": {
                          "width": 300,
                          "height": 250
                        },
                        "iframeHtml": "\u003Ciframe src=\"https://cdn.example.com/assets/201427/randomPath/index.html\" width=\"300\" height=\"250\" frameborder=\"0\" scrolling=\"no\" marginheight=\"0\" marginwidth=\"0\"\u003E\u003C/iframe\u003E",
                        "zipFile": true,
                        "disposable": false,
                        "html5Creative": true
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommonResponse"
                },
                "examples": {
                  "Asset not found": {
                    "description": "Asset not found",
                    "value": {
                      "success": false,
                      "errorObjects": [
                        {
                          "error": "No Asset found with the Asset ID provided. Please provide a valid ID."
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "errorObjects": [
                    {
                      "error": "server encountered an error !"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "errorObjects": [
                    {
                      "error": "Forbidden !"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "MCP"
        ],
        "summary": "Delete Asset by Asset ID",
        "description": "This API is used for deleting a single asset identified by its AssetID.\n1. The 'assetId' parameter should contain the ID of the asset to be deleted.\n2. The API returns a confirmation message upon successful deletion of the asset.\n3. Appropriate error responses are provided for invalid inputs or unauthorized access.\n4. It is a soft delete; the asset is marked as deleted in the system but not permanently removed from storage.\n",
        "operationId": "deleteAsset",
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "description": "The ID of the asset to delete.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Authorization Bearer Token",
            "example": "Bearer 0ed52da8-24ab-44b1-bc88-7ea03a090d24",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "example": "{{bearer_token}}"
            }
          },
          {
            "name": "X-IAA-OW-ID",
            "in": "header",
            "description": "Organization Workspace Id",
            "example": 1,
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
