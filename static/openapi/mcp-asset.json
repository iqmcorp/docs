      "patch": {
        "tags": [
          "MCP"
        ],
        "summary": "Update Asset Details by Asset ID",
        "description": "This API is used for updating the details of a single asset identified by its AssetID.\n1. The 'assetId' parameter should contain the ID of the asset to be updated.\n2. The request body should contain the new details for the asset, including storage path, CDN URL,\nand optional disposable status.\n3. The API returns a confirmation message upon successful update of the asset details.\n4. Appropriate error responses are provided for invalid inputs or unauthorized access.\n",
        "operationId": "updateAssetDetails",
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "description": "The ID of the asset to update.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Authorization Bearer Token",
            "example": "Bearer 0ed52da8-24ab-44b1-bc88-7ea03a090d24",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "example": "{{bearer_token}}"
            }
          },
          {
            "name": "X-IAA-OW-ID",
            "in": "header",
            "description": "Organization Workspace Id",
            "example": 1,
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "description": "The new details for the asset.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetUpdateVO"
              },
